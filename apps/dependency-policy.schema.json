{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["minimumReleaseAgeMinutes", "directDependencyAllowlist"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "minimumReleaseAgeMinutes": {
      "type": "integer",
      "minimum": 10080
    },
    "minimumReleaseAgeExclude": {
      "$ref": "#/$defs/dependencyNames"
    },
    "directDependencyAllowlist": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "dependencies": {
            "$ref": "#/$defs/dependencyNames"
          },
          "devDependencies": {
            "$ref": "#/$defs/dependencyNames"
          },
          "peerDependencies": {
            "$ref": "#/$defs/dependencyNames"
          },
          "optionalDependencies": {
            "$ref": "#/$defs/dependencyNames"
          }
        }
      }
    }
  },
  "$defs": {
    "dependencyNames": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
