{
  "$schema": "./dependency-policy.schema.json",
  "minimumReleaseAgeMinutes": 10080,
  "minimumReleaseAgeExclude": ["@types/node", "vite", "@rolldown/*"],
  "directDependencyAllowlist": {
    "@app/apps": {
      "devDependencies": ["postcss", "prettier"]
    },
    "@app/desktop": {
      "dependencies": [
        "@app/native-bridge",
        "@dnd-kit/core",
        "@dnd-kit/sortable",
        "@fontsource-variable/montserrat",
        "@hookform/resolvers",
        "@radix-ui/react-checkbox",
        "@radix-ui/react-context-menu",
        "@radix-ui/react-dropdown-menu",
        "@radix-ui/react-popover",
        "@radix-ui/react-radio-group",
        "@radix-ui/react-switch",
        "@radix-ui/react-tooltip",
        "@tanstack/react-query",
        "@tanstack/react-router",
        "@tanstack/react-virtual",
        "@tauri-apps/api",
        "@xyflow/react",
        "clsx",
        "elkjs",
        "i18next",
        "lucide-react",
        "react",
        "react-dom",
        "react-hook-form",
        "react-i18next",
        "react-markdown",
        "rehype-sanitize",
        "remark-gfm",
        "shadcn",
        "sonner",
        "tailwind-merge",
        "tw-animate-css",
        "zod"
      ],
      "devDependencies": [
        "@eslint/js",
        "@tailwindcss/vite",
        "@tauri-apps/cli",
        "@testing-library/jest-dom",
        "@testing-library/react",
        "@testing-library/user-event",
        "@types/node",
        "@types/react",
        "@types/react-dom",
        "@vitejs/plugin-react",
        "eslint",
        "eslint-config-prettier",
        "eslint-plugin-jsx-a11y",
        "eslint-plugin-react-hooks",
        "eslint-plugin-react-refresh",
        "eslint-plugin-testing-library",
        "jsdom",
        "tailwindcss",
        "typescript",
        "typescript-eslint",
        "vite",
        "vitest"
      ]
    },
    "@app/native-bridge": {
      "dependencies": [
        "@tauri-apps/api",
        "@tauri-apps/plugin-clipboard-manager"
      ],
      "devDependencies": ["typescript", "vitest"]
    }
  }
}
