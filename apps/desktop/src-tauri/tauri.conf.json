{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kent",
  "mainBinaryName": "kent-desktop",
  "version": "0.0.0",
  "identifier": "sh.kent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kent",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "transparent": true,
        "dragDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 12,
          "y": 22
        }
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; font-src 'self'; connect-src ipc: http://ipc.localhost ws://127.0.0.1:* ws://localhost:* ws://*:* wss://*:*; object-src 'none'; frame-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage", "deb"],
    "category": "DeveloperTool",
    "shortDescription": "Desktop client for the Kent coding agent.",
    "longDescription": "Kent Desktop is a GUI remote-control client for a running Kent coding-agent server — boards, task detail, and the workflow editor. It connects to a local Kent service over loopback; install and start the Kent CLI/service first.",
    "homepage": "https://github.com/respawn-llc/kent",
    "publisher": "Respawn LLC",
    "copyright": "© 2026 Respawn LLC",
    "license": "AGPL-3.0-only",
    "licenseFile": "../../../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist"
    },
    "linux": {
      "deb": {
        "section": "devel"
      }
    }
  }
}
