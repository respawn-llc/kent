{
  "name": "@builder/desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:browser": "vite --host 127.0.0.1 --open /",
    "dev:showcase": "vite --host 127.0.0.1 --open /dev-showcase.html",
    "build": "pnpm build:web",
    "build:web": "tsc -b --pretty false && vite build && node ../scripts/check-desktop-font-assets.mjs",
    "preview": "vite preview",
    "lint": "eslint src packages",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
